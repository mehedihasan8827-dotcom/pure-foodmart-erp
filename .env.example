# ============================================================
# Pure Foodmart ERP — environment template
#
# Copy to `.env` for local development ONLY.
# In staging/production these values live in the hosting
# platform's secret manager (Fly.io secrets / Render env),
# NEVER in this repository and NEVER in chat.
# ============================================================

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Database (docker-compose local defaults) ---
DATABASE_URL=postgres://erp:erp_local_dev@localhost:5432/pure_foodmart_erp

# --- Redis (queues, BullMQ — wired in B4) ---
REDIS_URL=redis://localhost:6379

# --- Nuport OMS integration (B4) ---
NUPORT_COMPANY_ID=
NUPORT_API_KEY=
# Random secret embedded in our webhook URL path (defense-in-depth, §2.2)
NUPORT_WEBHOOK_SECRET=

# --- Steadfast Courier integration (B5) ---
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# --- Auth (B7) ---
JWT_SECRET=
SESSION_COOKIE_SECRET=

# --- Object storage for receipt photos / settlement CSVs (B6) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
