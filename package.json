{
  "name": "pure-foodmart-erp",
  "version": "0.1.0",
  "private": true,
  "description": "Pure Foodmart — Financial ERP & Cash Flow Management System (Nuport + Steadfast dual pipeline)",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "db:migrate": "pnpm --filter @pfm/db migrate",
    "db:seed": "pnpm --filter @pfm/db seed",
    "db:status": "pnpm --filter @pfm/db status",
    "typecheck": "pnpm -r run typecheck",
    "dev:api": "pnpm --filter @pfm/api dev",
    "dev:worker": "pnpm --filter @pfm/worker dev",
    "dev:web": "pnpm --filter @pfm/web dev"
  }
}
